# Runtime
ARTIFACT_DIR=artifacts
BROWSER_PROVIDER=local

# External provider benchmarks are opt-in.
# Leave unset for local/mock mode.

# Managed browser API
MANAGED_BROWSER_API_KEY=
MANAGED_BROWSER_REGION=
MANAGED_BROWSER_SESSION_ID=

# Scraping API
SCRAPING_API_KEY=
SCRAPING_API_REGION=

# Proxy-backed browser
PROXY_URL=
PROXY_REGION=
PROXY_SESSION_ID=

# Benchmark runtime
PROVIDER_BENCHMARK_TIMEOUT_SECONDS=30
PROVIDER_BENCHMARK_MAX_RETRIES=0
